# ==============================================================================
# .gitignore for Academic Codex Workflow Projects
# ==============================================================================

# LaTeX build artifacts
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.log
*.nav
*.out
*.snm
*.toc
*.vrb
*.synctex.gz
*.run.xml
*-blx.bib

# Compiled PDFs (uncomment to track specific PDFs)
# *.pdf

# Python
__pycache__/
*.pyc
*.pyo

# R
.Rproj.user/
.Rhistory
.RData
.Rdata

# OS files
.DS_Store
Thumbs.db

# Local workflow state (not shared across machines)
.codex/state/
.claude/settings.local.json
.claude/state/
quality_reports/tmp/review_state/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Quarto rendering artifacts
/.quarto/

# Cloned repos in supporting docs — now tracked as git submodules
# master_supporting_docs/Tariffs_ECB/
# master_supporting_docs/MCMS/

# Output artifacts — uncomment lines below based on your preference
# *.rds
# output/**/*.rds
