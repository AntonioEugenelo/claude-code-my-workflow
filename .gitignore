# ==============================================================================
# .gitignore for Academic Claude Code Projects
# ==============================================================================

# LaTeX build artifacts
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.log
*.nav
*.out
*.snm
*.toc
*.vrb
*.synctex.gz
*.run.xml
*-blx.bib

# Compiled PDFs (uncomment to track specific PDFs)
# *.pdf

# Python
__pycache__/
*.pyc
*.pyo

# R
.Rproj.user/
.Rhistory
.RData
.Rdata

# OS files
.DS_Store
Thumbs.db
__MACOSX/
._*

# Claude Code local files (not shared across machines)
.claude/settings.local.json
.claude/state/
CLAUDE.local.md

# Codex local hook/runtime state
quality_reports/hook_state/

# IDE
.vscode/*
!.vscode/settings.json
.idea/
*.swp
*.swo
*~

# Quarto rendering artifacts
/.quarto/

# quality_reports/ -- keep structure, ignore per-session project state
quality_reports/plans/*
quality_reports/specs/*
quality_reports/session_logs/*
quality_reports/merges/*
quality_reports/decisions/*
quality_reports/checkpoints/*
quality_reports/claim_ledgers/*
quality_reports/preregistrations/*
quality_reports/run_cards/*
quality_reports/run_state/*
!quality_reports/plans/.gitkeep
!quality_reports/specs/.gitkeep
!quality_reports/session_logs/.gitkeep
!quality_reports/merges/.gitkeep
!quality_reports/decisions/.gitkeep
!quality_reports/decisions/ACTIVE.md
!quality_reports/decisions/source_authority.md
!quality_reports/claim_ledgers/.gitkeep
!quality_reports/claim_ledgers/README.md
!quality_reports/claim_ledgers/TEMPLATE.md
!quality_reports/checkpoints/.gitkeep
!quality_reports/preregistrations/.gitkeep
!quality_reports/run_cards/.gitkeep
!quality_reports/run_cards/README.md
!quality_reports/run_cards/TEMPLATE.md

# R analysis outputs
scripts/R/_outputs/

# Cloned repos in supporting docs — now tracked as git submodules
# master_supporting_docs/Tariffs_ECB/
# master_supporting_docs/MCMS/

# Output artifacts — uncomment lines below based on your preference
# *.rds
# output/**/*.rds
