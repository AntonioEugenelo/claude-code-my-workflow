+// -----------------------------------------------------------------------------
+// [FP.1] Leeper-Plante-Traum-style fiscal rules for VAT, labour-income tax,
+//        and sector-specific production tax/subsidy wedges.
+// tau_C_k is d log(1+T^C_k,t). Positive = higher VAT wedge.
+// tau_N_k is d log(1/(1-T^N_k,t)). Positive = higher household labour-income tax wedge.
+// tau_Y_k_i is d log(1+T^Y_k_i,t). Positive = production tax; negative = subsidy.
+// The selected specification uses y_k,t as the cyclical indicator and lagged bgov_k as debt.
+// Default calibration: VAT and production wedges respond to output; labour tax responds to debt.
+// -----------------------------------------------------------------------------
+@#for k in 1:Knum
+    tau_C_@{k} = rho_tau_C_@{k} * tau_C_@{k}(-1)
+        + (1-rho_tau_C_@{k}) * (phi_tau_C_y_@{k} * y_@{k} + phi_tau_C_b_@{k} * bgov_@{k}(-1))
+        + sigma_tau_C_@{k} * varepsilon_tau_C_@{k};
+
+    tau_N_@{k} = rho_tau_N_@{k} * tau_N_@{k}(-1)
+        + (1-rho_tau_N_@{k}) * (phi_tau_N_y_@{k} * y_@{k} + phi_tau_N_b_@{k} * bgov_@{k}(-1))
+        + sigma_tau_N_@{k} * varepsilon_tau_N_@{k};
+
+    @#for i in 1:Inum
+        tau_Y_@{k}_@{i} = rho_tau_Y_@{k}_@{i} * tau_Y_@{k}_@{i}(-1)
+            + (1-rho_tau_Y_@{k}_@{i}) * (phi_tau_Y_y_@{k}_@{i} * y_@{k} + phi_tau_Y_b_@{k}_@{i} * bgov_@{k}(-1))
+            + sigma_tau_Y_@{k}_@{i} * varepsilon_tau_Y_@{k}_@{i};
+    @#endfor
