{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$root = (git rev-parse --show-toplevel).Trim(); python (Join-Path $root '.codex/hooks/bash_command_guard.py')\"",
            "statusMessage": "Checking Bash command policy",
            "timeout": 10
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$root = (git rev-parse --show-toplevel).Trim(); python (Join-Path $root '.codex/hooks/bash_command_guard.py')\"",
            "statusMessage": "Checking approval request policy",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$root = (git rev-parse --show-toplevel).Trim(); python (Join-Path $root '.codex/hooks/stop_review_enforcer.py')\"",
            "statusMessage": "Checking review enforcement state",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
